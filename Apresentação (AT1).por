programa {

  funcao inicio() 

  {
    inteiro idade
    cadeia nome
    cadeia cidade
    cadeia profissao
    

    escreva ("Digite seu nome. ")
    leia (nome)
    escreva ("Digite sua idade. ")
    leia (idade)
    escreva ("Digite sua cidade. ")
    leia (cidade)
    escreva ("Digite sua profissão. ")
    leia (profissao)
    
   
    escreva ("\n Olá meu nome é ", nome, " tenho ", idade, " anos, moro em ", cidade, " e trabalho como ", profissao )
   


  }

}
